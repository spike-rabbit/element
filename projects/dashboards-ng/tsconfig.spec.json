{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "types": [
      "vitest/globals",
      "vitest/browser",
      "@spike-rabbit/element-translate-ng/localize-types",
      "node"
    ],
    "lib": ["es2022", "dom", "esnext.disposable"],
    "paths": {
      "@spike-rabbit/element-translate-ng": [
        "projects/element-translate-ng/public-api.ts",
        "projects/element-translate-ng/"
      ],
      "@spike-rabbit/element-translate-ng/*": ["projects/element-translate-ng/*"],
      "@spike-rabbit/element-ng": ["projects/element-ng/public-api.ts", "projects/element-ng"],
      "@spike-rabbit/element-ng/*": ["projects/element-ng/*"],
      "@spike-rabbit/dashboards-ng": [
        "projects/dashboards-ng/src/public-api.ts",
        "projects/dashboards-ng/src"
      ]
    }
  },
  "include": ["**/*.spec.ts", "**/*.d.ts", "**/test/**/*.ts"]
}
