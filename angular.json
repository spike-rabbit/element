    "dashboards-demo": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/dashboards-demo",
      "sourceRoot": "projects/dashboards-demo/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "ngx-build-plus:browser",
          "options": {
            "outputPath": "dist/dashboards-demo",
            "index": "projects/dashboards-demo/src/index.html",
            "main": "projects/dashboards-demo/src/main.ts",
            "tsConfig": "projects/dashboards-demo/tsconfig.app.json",
            "aot": true,
            "assets": [
              "projects/dashboards-demo/src/assets",
              "projects/dashboards-demo/src/favicon.png",
              {
                "glob": "*",
                "input": "projects/dashboards-ng/assets/i18n",
                "output": "assets/i18n/dashboards-ng/"
              },
              {
                "glob": "*.svg",
                "input": "node_modules/@meteocons/svg-static/fill",
                "output": "/assets/meteocons/"
              }
            ],
            "stylePreprocessorOptions": {
              "includePaths": ["node_modules/"]
            },
            "styles": [
              "projects/dashboards-demo/src/styles.scss",
              "node_modules/gridstack/dist/gridstack.css"
            ],
            "extraWebpackConfig": "projects/dashboards-demo/webpack.config.cjs",
            "allowedCommonJsDependencies": [
              "echarts",
              "gridstack",
              "@angular-architects/module-federation"
            ],
            "vendorChunk": true,
            "extractLicenses": false,
            "sourceMap": true,
            "optimization": false,
            "namedChunks": true
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/dashboards-demo/tsconfig.app.prod.json",
              "fileReplacements": [
                {
                  "replace": "projects/dashboards-demo/src/environments/environment.ts",
                  "with": "projects/dashboards-demo/src/environments/environment.prod.ts"
                }
              ],
              "crossOrigin": "use-credentials",
              "optimization": true,
              "outputHashing": "all",
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ]
            },
            "demo-deployment": {
              "fileReplacements": [
                {
                  "replace": "projects/dashboards-demo/src/environments/environment.ts",
                  "with": "projects/dashboards-demo/src/environments/environment.prod.ts"
                }
              ]
            }
          }
        },
        "serve": {
          "builder": "ngx-build-plus:dev-server",
          "options": {
            "port": 4201,
            "extraWebpackConfig": "projects/dashboards-demo/webpack.config.cjs",
            "buildTarget": "dashboards-demo:build"
          },
          "configurations": {
            "production": {
              "buildTarget": "dashboards-demo:build:production",
              "extraWebpackConfig": "projects/dashboards-demo/webpack.config.prod.cjs"
            },
            "development": {
              "buildTarget": "dashboards-demo:build"
            }
          },
          "defaultConfiguration": "development"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "cache": true,
            "lintFilePatterns": [
              "projects/dashboards-demo/src/**/*.ts",
              "projects/dashboards-demo/src/**/*.html"
            ],
            "eslintConfig": "projects/dashboards-demo/eslint.config.mjs"
          }
        },
        "esbuild": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "dist/dashboards-demo-esm",
              "browser": ""
            },
            "index": "projects/dashboards-demo/src/index.html",
            "browser": "projects/dashboards-demo/src/main.ts",
            "polyfills": ["es-module-shims"],
            "tsConfig": "projects/dashboards-demo/tsconfig.app.json",
            "aot": true,
            "fileReplacements": [
              {
                "replace": "projects/dashboards-demo/src/environments/environment.ts",
                "with": "projects/dashboards-demo/src/environments/environment.esm.ts"
              }
            ],
            "assets": [
              "projects/dashboards-demo/src/assets",
              "projects/dashboards-demo/src/favicon.png",
              {
                "glob": "*",
                "input": "projects/dashboards-ng/assets/i18n",
                "output": "assets/i18n/dashboards-ng/"
              }
            ],
            "stylePreprocessorOptions": {
              "includePaths": ["node_modules/"]
            },
            "styles": [
              "projects/dashboards-demo/src/styles-esm.scss",
              "node_modules/gridstack/dist/gridstack.css"
            ],
            "allowedCommonJsDependencies": [
              "echarts",
              "gridstack",
              "@angular-architects/module-federation",
              "@module-federation/runtime"
            ],
            "extractLicenses": false,
            "sourceMap": true,
            "optimization": false,
            "namedChunks": true
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/dashboards-demo/tsconfig.app.prod.json",
              "fileReplacements": [
                {
                  "replace": "projects/dashboards-demo/src/environments/environment.ts",
                  "with": "projects/dashboards-demo/src/environments/environment.esm.prod.ts"
                }
              ],
              "crossOrigin": "use-credentials",
              "optimization": true,
              "outputHashing": "all",
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          }
        },
        "build-esm": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "entryPoints": ["projects/dashboards-demo/src/main.ts"],
            "projectName": "dashboards-demo"
          },
          "configurations": {
            "production": {
              "target": "dashboards-demo:esbuild:production"
            },
            "development": {
              "target": "dashboards-demo:esbuild:development",
              "dev": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve-esm": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "dashboards-demo:serve-esm-original:development",
            "rebuildDelay": 500,
            "dev": true,
            "cacheExternalArtifacts": false,
            "port": 0,
            "entryPoints": ["projects/dashboards-demo/src/main.ts"],
            "projectName": "dashboards-demo"
          }
        },
        "serve-esm-original": {
          "builder": "@angular/build:dev-server",
          "options": {
            "port": 4204,
            "buildTarget": "dashboards-demo:build-esm"
          },
          "configurations": {
            "production": {
              "buildTarget": "dashboards-demo:esbuild:production"
            },
            "development": {
              "buildTarget": "dashboards-demo:esbuild:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    },
    "dashboards-demo-webcomponents": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/dashboards-demo/webcomponents",
      "sourceRoot": "projects/dashboards-demo/webcomponents/src",
