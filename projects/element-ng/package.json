{
  "name": "@spike-rabbit/element-ng",
  "description": "Element Angular component library, implementing the Siemens Design Language",
  "version": "50.0.4",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spike-rabbit/element.git"
  },
  "author": {
    "name": "Siemens AG",
    "email": "info@siemens.com"
  },
  "homepage": "https://github.com/spike-rabbit/element",
  "bugs": "https://github.com/spike-rabbit/element/issues/new",
  "publishConfig": {
    "access": "public",
    "directory": "../../dist/@spike-rabbit/element-ng"
  },
  "type": "module",
  "schematics": "./schematics/collection.json",
  "ng-add": {
    "save": "dependencies"
  },
  "ng-update": {
    "packageGroup": [
      "@spike-rabbit/charts-ng",
      "@spike-rabbit/dashboards-ng",
      "@spike-rabbit/element-ng",
      "@spike-rabbit/element-theme",
      "@spike-rabbit/element-translate-ng",
      "@spike-rabbit/live-preview",
      "@spike-rabbit/maps-ng",
      "@spike-rabbit/native-charts-ng"
    ],
    "migrations": "./schematics/migration.json"
  },
  "peerDependencies": {
    "@angular/cdk": "22",
    "@angular/common": "22",
    "@angular/core": "22",
    "@angular/forms": "22",
    "@angular/router": "22",
    "@ngx-formly/bootstrap": "^6.2.2 || ^7.0.1",
    "@ngx-formly/core": "^6.2.2 || ^7.0.1",
    "@siemens/element-icons": "1",
    "@siemens/ngx-datatable": "22 - 26",
    "@spike-rabbit/element-theme": "workspace:*",
    "@spike-rabbit/element-translate-ng": "workspace:*",
    "ag-grid-community": "^34.3.1 || ^35.0.0 || ^36.0.0",
    "flag-icons": "^7.3.2",
    "google-libphonenumber": "^3.2.40",
    "ngx-image-cropper": "^9.0.0"
  },
  "peerDependenciesMeta": {
    "@ngx-formly/bootstrap": {
      "optional": true
    },
    "@ngx-formly/core": {
      "optional": true
    },
    "@siemens/ngx-datatable": {
      "optional": true
    },
    "ngx-image-cropper": {
      "optional": true
    },
    "flag-icons": {
      "optional": true
    },
    "google-libphonenumber": {
      "optional": true
    },
    "ag-grid-community": {
      "optional": true
    }
  }
}
